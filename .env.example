# ── Job Intelligence System — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values (local dev only).
# On Streamlit Cloud, add these in: App settings → Secrets (TOML format).
# NEVER commit .env to git — it contains your API keys.

# ── Required ───────────────────────────────────────────────────────────────────

# Your Anthropic API key (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily search API key (https://app.tavily.com → API Keys)
# Free tier: 1000 searches/month (~200 full pipeline runs)
TAVILY_API_KEY=tvly-...

# ── Supabase + Voyage AI (JD database — strongly recommended) ─────────────────
# Supabase project URL — Supabase Dashboard → Project Settings → API → Project URL
# Looks like: https://abcdefghij.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key — Project Settings → API → Project API keys → anon public
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Voyage AI API key — https://dash.voyageai.com → API Keys
# Free tier: 50 million tokens/month
VOYAGE_API_KEY=pa-...

# ── Auth (beta password gate) ─────────────────────────────────────────────────
# Single shared password for all beta users. Leave blank to disable the gate
# (useful for local dev). Set this on Streamlit Cloud via Secrets, not here.
# APP_PASSWORD=your-beta-password

# ── Razorpay (payments / credits) ─────────────────────────────────────────────
# Create an account at https://razorpay.com and generate API keys.
# Use rzp_test_... keys during development; switch to rzp_live_... for production.
# APP_URL is the full URL of your deployed Streamlit app — used as the Razorpay
# payment callback redirect URL (e.g. https://yourapp.streamlit.app).
# APP_URL=https://your-app.streamlit.app
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── Optional ───────────────────────────────────────────────────────────────────

# Daily spend cap in USD. Pipeline aborts if this is exceeded.
# Recommended: 5.00–10.00 during beta to avoid surprises.
# Set to 0 to disable the guard entirely.
DAILY_COST_CAP_USD=5.00

# Google Sheets feedback (optional — see feedback_store.py for setup)
# FEEDBACK_SHEET_ID=your-google-sheet-id-here

# Override default storage paths (optional)
# JD_DB_PATH=saved_inputs/jd_store.db
# LOG_DIR=logs
# CACHE_DIR=.cache
